PORT=5000
MONGODB_URI=mongodb://localhost:27017/patient-counselling
JWT_SECRET=patient_counselling_secret_key_2024_change_in_production

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Meet API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com
FRONTEND_URL=http://localhost:3000


# Separate Socket Server (set this when deploying socket server separately, e.g. Railway/Render)
# Leave empty to use the built-in Socket.IO on this server
SOCKET_SERVER_URL=https://your-socket-server.railway.app
# Shared secret between backend and socket server for the /emit endpoint
INTERNAL_SECRET=change_this_to_a_random_secret
